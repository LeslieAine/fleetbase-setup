# ─────────────────────────────────────────────────────────────
# YOUR COURIER NETWORK — Environment Configuration
# Copy this to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# App
APP_NAME="YourCourierNetwork"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Generate with: php artisan key:generate --show
# Or: openssl rand -base64 32
APP_KEY=base64:GENERATE_ME_WITH_COMMAND_ABOVE

# Admin account created on first setup
ADMIN_NAME="Your Name"
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changeme123

# Database
DB_DATABASE=fleetbase
DB_USERNAME=fleetbase
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Real-time (Pusher-compatible via your own Socket.IO)
# Leave these as-is for local setup — socketio container handles it
PUSHER_APP_ID=fleetbase-local
PUSHER_APP_KEY=fleetbase-local-key
PUSHER_APP_SECRET=fleetbase-local-secret

# Email — use 'log' for local dev (emails go to Laravel log)
# For production: smtp, mailgun, ses
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ─────────────────────────────────────────────────────────────
# PLATFORM BUSINESS RULES
# ─────────────────────────────────────────────────────────────

# Your commission percentage (riders keep the rest)
# 7 = 7% to you, 93% to rider
PLATFORM_COMMISSION_PERCENTAGE=7

# Maximum packages one rider can carry at once
MAX_PACKAGES_PER_RIDER=3

# Radius in KM to look for nearby pickups for a rider already on a trip
NEARBY_PICKUP_RADIUS_KM=2

# ─────────────────────────────────────────────────────────────
# MEDUSA INTEGRATION
# ─────────────────────────────────────────────────────────────

# Your Medusa backend URL
# Use host.docker.internal to reach localhost from inside Docker
MEDUSA_BACKEND_URL=http://host.docker.internal:9000

# Secret used to verify webhooks between Fleetbase and Medusa
# Generate: openssl rand -hex 32
MEDUSA_WEBHOOK_SECRET=generate_a_secret_here

# ─────────────────────────────────────────────────────────────
# NOTIFICATIONS (optional for local dev)
# ─────────────────────────────────────────────────────────────

# Africa's Talking for SMS (UG, KE, NG, GH, TZ)
# Sign up at: africastalking.com
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=

# FCM for push notifications on rider app
# Get from Firebase console
FCM_SERVER_KEY=

# ─────────────────────────────────────────────────────────────
# MAPS
# ─────────────────────────────────────────────────────────────

# Google Maps (for geocoding addresses to lat/lng)
# Free tier: 200 USD/month credit
GOOGLE_MAPS_API_KEY=

# Or use free OpenStreetMap Nominatim (no key needed)
# Set GEOCODING_PROVIDER=nominatim to use it
GEOCODING_PROVIDER=google
